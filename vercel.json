{
    "rewrites": [
        {
            "source": "/auth/callback",
            "destination": "/index.html"
        },
        {
            "source": "/auth/:path*",
            "destination": "https://governance-multi-tenant-rag.onrender.com/auth/:path*"
        },
        {
            "source": "/api/:path*",
            "destination": "https://governance-multi-tenant-rag.onrender.com/api/:path*"
        },
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ]
}